# App
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://orchestrator_user:orchestrator_pass@localhost:5432/orchestrator_db

# Redis
